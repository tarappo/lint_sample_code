{
    "problemMatcher": [
      {
        "owner": "dart-custom_lint-matcher",
        "pattern": [
          {
            "regexp": "  (.+):(\\d+):(\\d+)\\s(•.+)(•.+)•\\s(WARNING|ERROR)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4,
            "code": 5,
            "severity": 6
          }
        ]
      }
    ]
}
