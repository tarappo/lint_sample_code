{
    "problemMatcher": [
      {
        "owner": "dart-custom_lint-matcher",
        "pattern": [
          {
            "regexp": "^(.+):(\\d+):(\\d+)(.+)\\s(WARNING|ERROR)",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4,
            "severity": 5
          }
        ]
      }
    ]
}
